          { "name": "paymasterAndData", "type": "bytes" },
          { "name": "signature", "type": "bytes" }
        ]
      },
      { "name": "beneficiary", "type": "address" }
    ],
    "outputs": []
  },
  {
    "type": "function",
    "name": "simulateValidation",
    "stateMutability": "nonpayable",
    "inputs": [
